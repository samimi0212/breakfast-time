{
  "crons": [
    {
      "path": "/api/cron-lifecycle-emails",
      "schedule": "0 9 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "breakfast-time.fr" }],
      "destination": "https://www.breakfast-time.fr/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
